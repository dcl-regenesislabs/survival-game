{
  "compilerOptions": {
    "allowJs": true,
    "strict": true,
    "typeRoots": [
      "node_modules/@dcl/sdk/node_modules",
      "node_modules/@types"
    ],
    "baseUrl": ".",
    "paths": {
      "@dcl/asset-packs/*": ["node_modules/@dcl/inspector/node_modules/@dcl/asset-packs/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "assets/**/*.ts",
    "assets/**/*.tsx"
  ],
  "extends": "@dcl/sdk/types/tsconfig.ecs7.json"
}
